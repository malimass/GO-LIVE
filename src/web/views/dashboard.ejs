<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GO-LIVE Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header>
    <div class="header-content">
      <h1>GO-LIVE</h1>
      <div class="header-right">
        <span id="live-badge" class="badge <%= isLive ? 'badge-live' : 'badge-offline' %>">
          <%= isLive ? 'LIVE' : 'OFFLINE' %>
        </span>
        <a href="/logout" class="btn btn-sm">Logout</a>
      </div>
    </div>
  </header>

  <main>
    <!-- Stream Status -->
    <section class="card">
      <h2>Stato Stream</h2>
      <div id="destinations" class="destinations-grid">
        <% if (statuses.length === 0) { %>
          <p class="muted">Nessun stream attivo. Le destinazioni appariranno quando la camera si connette.</p>
        <% } %>
        <% statuses.forEach(function(s) { %>
          <div class="dest-card dest-<%= s.status %>" data-name="<%= s.name %>">
            <div class="dest-header">
              <span class="dest-icon"><%= s.platform === 'facebook' ? 'FB' : 'IG' %></span>
              <span class="dest-name"><%= s.name %></span>
            </div>
            <div class="dest-status"><%= s.status %></div>
            <% if (s.health) { %>
              <div class="dest-health">
                <span><%= s.health.fps %> fps</span>
                <span><%= s.health.bitrate %></span>
              </div>
            <% } %>
          </div>
        <% }); %>
      </div>
      <div class="controls" style="margin-top:1rem;">
        <button class="btn btn-danger" onclick="stopStream()" id="btn-stop" <%= !isLive ? 'disabled' : '' %>>
          Ferma Distribuzione
        </button>
      </div>
    </section>

    <!-- Facebook Config -->
    <section class="card">
      <h2>Facebook</h2>
      <div id="fb-list">
        <% fbDests.forEach(function(fb) { %>
          <div class="config-row" data-id="<%= fb.id %>">
            <div class="config-fields">
              <input type="text" value="<%= fb.name %>" placeholder="Nome (es. Pagina 1)" class="fb-name">
              <input type="text" value="<%= fb.rtmp_url %>" placeholder="RTMP URL" class="fb-url">
              <input type="text" value="<%= fb.stream_key %>" placeholder="Stream Key" class="fb-key">
            </div>
            <div class="config-actions">
              <button class="btn btn-sm btn-primary" onclick="saveFb(this)">Salva</button>
              <button class="btn btn-sm btn-danger" onclick="deleteFb(<%= fb.id %>)">X</button>
            </div>
          </div>
        <% }); %>
      </div>
      <button class="btn btn-sm" onclick="addFbRow()" style="margin-top:0.75rem;">+ Aggiungi Pagina Facebook</button>
    </section>

    <!-- Instagram Config -->
    <section class="card">
      <h2>Instagram</h2>
      <div id="ig-list">
        <% igAccounts.forEach(function(ig) { %>
          <div class="config-row" data-id="<%= ig.id %>">
            <div class="config-fields">
              <input type="text" value="<%= ig.name %>" placeholder="Nome (es. Account 1)" class="ig-name">
              <input type="text" value="<%= ig.username %>" placeholder="Username" class="ig-username">
              <input type="text" value="<%= ig.live_title || 'LIVE' %>" placeholder="Titolo Live" class="ig-title">
              <select class="ig-audience">
                <option value="public" <%= (ig.audience || 'public') === 'public' ? 'selected' : '' %>>Tutti</option>
                <option value="practice" <%= (ig.audience) === 'practice' ? 'selected' : '' %>>Diretta di prova</option>
                <option value="close_friends" <%= (ig.audience) === 'close_friends' ? 'selected' : '' %>>Amici stretti</option>
              </select>
              <span class="cookie-status <%= ig.hasCookies ? 'cookie-ok' : 'cookie-missing' %>">
                <%= ig.hasCookies ? 'Cookie OK' : 'No cookie' %>
                <% if (ig.last_cookie_update) { %><small>(<%= ig.last_cookie_update %>)</small><% } %>
              </span>
            </div>
            <div class="config-actions">
              <button class="btn btn-sm btn-primary" onclick="saveIg(this)">Salva</button>
              <button class="btn btn-sm" onclick="showCookieUpload(<%= ig.id %>)">Cookie</button>
              <button class="btn btn-sm btn-danger" onclick="deleteIg(<%= ig.id %>)">X</button>
            </div>
          </div>
        <% }); %>
      </div>
      <button class="btn btn-sm" onclick="addIgRow()" style="margin-top:0.75rem;">+ Aggiungi Account Instagram</button>
    </section>

    <!-- Cookie Upload Modal -->
    <div id="cookie-modal" class="modal hidden">
      <div class="modal-content">
        <h3>Upload Cookie Instagram</h3>
        <p>Incolla i cookie esportati dal browser (formato JSON array):</p>
        <textarea id="cookie-input" rows="10" placeholder='[{"name":"sessionid","value":"...","domain":".instagram.com",...}]'></textarea>
        <input type="hidden" id="cookie-account-id">
        <div class="modal-actions">
          <button class="btn" onclick="closeCookieModal()">Annulla</button>
          <button class="btn btn-primary" onclick="uploadCookies()">Salva Cookie</button>
        </div>
        <div id="cookie-result" class="hidden"></div>
      </div>
    </div>

    <!-- Logs -->
    <section class="card">
      <h2>Log</h2>
      <div id="logs" class="log-viewer">
        <p class="muted">Caricamento...</p>
      </div>
    </section>
  </main>

  <script src="/dashboard.js"></script>
</body>
</html>
